rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /weights/{weightId} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.weight is number
        && request.resource.data.weight >= 30
        && request.resource.data.weight <= 800
        && (request.resource.data.date is string || request.resource.data.weekStart is string);
      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid
        && request.resource.data.weight is number
        && request.resource.data.weight >= 30
        && request.resource.data.weight <= 800;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}
